---
import VenueBadge from './VenueBadge.astro';
import type { Publication } from '@lib/types';

interface Props {
  pub: Publication;
  authorName: string;
}

const { pub, authorName } = Astro.props;

const media = pub.media;
const isVideo = !!media && /\.(mp4|webm|mov|m4v)$/i.test(media);

function formatAuthors(authors: string[], name: string): string {
  const parts = name.trim().split(/\s+/);
  const firstName = parts[0] || '';
  const lastName = parts[parts.length - 1] || '';
  return authors.map(a => {
    const mm = a.trim().match(/^(.*?)\s*([*†‡+]+)$/);
    const bare = (mm ? mm[1] : a).trim();
    const sup = mm ? `<sup>${mm[2]}</sup>` : '';
    const aParts = bare.split(/\s+/);
    const aFirst = aParts[0] || '';
    const aLast = aParts[aParts.length - 1] || '';
    const lastMatch = aLast === lastName;
    const firstMatch = aFirst === firstName || (aFirst.length <= 2 && aFirst[0] === firstName[0]);
    return (lastMatch && firstMatch)
      ? `<strong class="text-[var(--color-text)]">${bare}</strong>${sup}`
      : `${bare}${sup}`;
  }).join(', ');
}
---

<div
  class="p-4 sm:p-5 rounded-xl bg-[var(--color-card-bg)] border border-[var(--color-border)] border-l-2 border-l-[var(--color-accent)]/30 card-hover"
  data-pub-card
  data-venue-type={pub.venueType}
  data-title={pub.title}
  data-authors={pub.authors.join(', ')}
  data-venue={pub.venue}
>
  <div class="flex flex-col sm:flex-row gap-4">
    {media && (
      <div class="w-full sm:w-56 md:w-72 sm:shrink-0">
        {isVideo ? (
          <video
            src={media}
            class="w-full rounded-lg border border-[var(--color-border)] bg-[var(--color-border)]"
            autoplay
            loop
            muted
            playsinline
            preload="metadata"
          ></video>
        ) : (
          <img
            src={media}
            alt={pub.title}
            class="w-full rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)]"
            loading="lazy"
          />
        )}
      </div>
    )}
    <div class="flex-1 min-w-0">
    <h3 class="font-medium leading-snug text-[var(--color-text)]">
      {pub.pdf || pub.url ? (
        <a href={pub.pdf || pub.url} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-accent)] transition-colors">{pub.title}</a>
      ) : pub.title}
    </h3>

      <p class="mt-1.5 text-sm text-[var(--color-text-secondary)]" set:html={formatAuthors(pub.authors, authorName)} />

      <div class="mt-2 flex flex-wrap items-center gap-2">
        <VenueBadge type={pub.venueType} />
        <span class="text-sm text-[var(--color-text-secondary)]">{pub.venue} {pub.year}</span>
      </div>

      <!-- Action links -->
      <div class="mt-3 flex flex-wrap gap-2">
        {pub.pdf && (
          <a href={pub.pdf} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 px-2.5 py-1 rounded-lg text-xs font-medium bg-[var(--color-border)]/50 hover:bg-[var(--color-accent)]/10 hover:text-[var(--color-accent)] transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            PDF
          </a>
        )}
        {pub.project && (
          <a href={pub.project} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 px-2.5 py-1 rounded-lg text-xs font-medium bg-[var(--color-border)]/50 hover:bg-[var(--color-accent)]/10 hover:text-[var(--color-accent)] transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.6 9h16.8M3.6 15h16.8M12 3a15 15 0 010 18M12 3a15 15 0 000 18"/></svg>
            Project
          </a>
        )}
        {pub.code && (
          <a href={pub.code} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 px-2.5 py-1 rounded-lg text-xs font-medium bg-[var(--color-border)]/50 hover:bg-[var(--color-accent)]/10 hover:text-[var(--color-accent)] transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
            Code
          </a>
        )}
        {pub.video && (
          <a href={pub.video} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 px-2.5 py-1 rounded-lg text-xs font-medium bg-[var(--color-border)]/50 hover:bg-[var(--color-accent)]/10 hover:text-[var(--color-accent)] transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Video
          </a>
        )}
        {pub.slides && (
          <a href={pub.slides} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 px-2.5 py-1 rounded-lg text-xs font-medium bg-[var(--color-border)]/50 hover:bg-[var(--color-accent)]/10 hover:text-[var(--color-accent)] transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
            Slides
          </a>
        )}
        {pub.demo && (
          <a href={pub.demo} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 px-2.5 py-1 rounded-lg text-xs font-medium bg-[var(--color-border)]/50 hover:bg-[var(--color-accent)]/10 hover:text-[var(--color-accent)] transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            Demo
          </a>
        )}
        {pub.model && (
          <a href={pub.model} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 px-2.5 py-1 rounded-lg text-xs font-medium bg-[var(--color-border)]/50 hover:bg-[var(--color-accent)]/10 hover:text-[var(--color-accent)] transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
            Model
          </a>
        )}
        {pub.data && (
          <a href={pub.data} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 px-2.5 py-1 rounded-lg text-xs font-medium bg-[var(--color-border)]/50 hover:bg-[var(--color-accent)]/10 hover:text-[var(--color-accent)] transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7c0 1.657 3.582 3 8 3s8-1.343 8-3-3.582-3-8-3-8 1.343-8 3z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v5c0 1.657 3.582 3 8 3s8-1.343 8-3V7M4 12v5c0 1.657 3.582 3 8 3s8-1.343 8-3v-5"/></svg>
            Data
          </a>
        )}
        {pub.benchmark && (
          <a href={pub.benchmark} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 px-2.5 py-1 rounded-lg text-xs font-medium bg-[var(--color-border)]/50 hover:bg-[var(--color-accent)]/10 hover:text-[var(--color-accent)] transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            Benchmark
          </a>
        )}
        {pub.doi && (
          <a href={`https://doi.org/${pub.doi}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 px-2.5 py-1 rounded-lg text-xs font-medium bg-[var(--color-border)]/50 hover:bg-[var(--color-accent)]/10 hover:text-[var(--color-accent)] transition-colors">
            DOI
          </a>
        )}
      </div>
    </div>
  </div>
</div>
